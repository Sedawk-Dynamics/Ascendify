# ============================================
# Ascendify - Common Environment Variables
# ============================================

# Domain (used by nginx proxy)
DOMAIN=yourdomain.com

# ---- Database ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=ascendify
DATABASE_URL=postgresql://postgres:password@db:5432/ascendify

# ---- Backend ----
PORT=5002
JWT_SECRET=your-strong-secret-key-change-in-production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=admin@ascendify.com

# ---- Frontend ----
BACKEND_URL=http://backend:5002

# ---- Admin ----
VITE_API_URL=/api
