generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Program {
  id          String   @id @default(uuid())
  title       String
  description String
  duration    String
  students    String
  rating      Float
  badge       String?
  image       String?
  category    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Certificate {
  id                 String   @id @default(uuid())
  certificateId      String   @unique
  holderName         String
  email              String
  college            String?
  birthDate          String?
  batch              String?
  programTitle       String
  issueDate          DateTime
  certificateHostUrl String?
  isValid            Boolean  @default(true)
  createdAt          DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(uuid())
  fullName  String
  email     String
  phone     String
  city      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CorporateInquiry {
  id                  String   @id @default(uuid())
  companyName         String
  contactPerson       String
  workEmail           String
  partnershipInterest String
  message             String?
  isRead              Boolean  @default(false)
  createdAt           DateTime @default(now())
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Job {
  id        String   @id @default(uuid())
  title     String
  company   String
  type      String
  location  String
  url       String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String
  author      String
  coverImage  String?
  category    String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
